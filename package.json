{
  "name": "@lenml/v4a-repair",
  "version": "1.0.2",
  "description": "v4a grammar repair",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup",
    "prepublish": "pnpm run build"
  },
  "keywords": [
    "v4a",
    "codex",
    "repair",
    "autofix",
    "repair",
    "code-agent",
    "coding-agent",
    "agent"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenML/v4a-repair.git"
  },
  "author": "lenml",
  "bugs": {
    "url": "https://github.com/lenML/v4a-repair/issues"
  },
  "homepage": "https://github.com/lenML/v4a-repair#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
